## AIX demo env (copy to /etc/aix-demo.env)

# Service port (recommended)
PORT=8011

# Optional: enable FastAPI docs endpoints (NOT recommended for public internet)
# ENABLE_DOCS=1

# Optional: protect merchant endpoints (/configure, /ingest)
# If set, requests must include header: X-Merchant-Token: <value>
# MERCHANT_TOKEN=change_me_to_a_long_random_string

# Optional: ZhipuAI online mode
# ZHIPUAI_API_KEY=your_key_here
# or
# ZHIPU_API_KEY=your_key_here
